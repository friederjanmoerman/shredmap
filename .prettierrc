{
	"printWidth": 150,
	"singleQuote": true,
	"jsxSingleQuote": false,
	"trailingComma": "all",
	"tabWidth": 2,
	"semi": false,
	"bracketSpacing": true,
	"bracketSameLine": false,
	"endOfLine": "auto",
	"plugins": ["prettier-plugin-svelte"],
	"overrides": [{ "files": "*.svelte", "options": { "parser": "svelte" } }]
}
